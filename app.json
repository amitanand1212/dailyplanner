{
  "expo": {
    "name": "Daily Planner",
    "slug": "daily-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dailyplanner",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F5FA"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dailyplanner.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F5FA"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#6C5CE7"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4121d85-4da4-4fed-bcea-bda207b482b4"
      }
    },
    "owner": "amitanand1212"
  }
}
